# Sepolia RPC endpoint
# Free options:
#   https://ethereum-sepolia-rpc.publicnode.com
#   https://rpc.sepolia.org
#   https://eth-sepolia.g.alchemy.com/v2/<your-key>
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Deployer private key (used by forge script for deploying mock contracts)
# This is your LOCAL deployer key. NEVER commit the actual value.
# NEVER share this key with any AI tool or chat — paste it only into this local file.
PRIVATE_KEY=0x...

# Optional: Etherscan API key for contract verification
# Get one at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=
